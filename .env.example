# lifi-cli environment variables
# Copy this file to .env and fill in the values you need.
# Run `lifi config show` to verify what is loaded.

# ── Write commands (deposit, approve) ────────────────────────────────────────
# Your wallet's private key. Required for any command that broadcasts a
# transaction. The derived address is used automatically as --from-address.
LIFI_WALLET_PRIVATE_KEY=

# ── Read commands that need a wallet address (quote, allowance, portfolio) ────
# Optional if LIFI_WALLET_PRIVATE_KEY is set — the address is derived from it.
# Set explicitly when you want to query a wallet without holding its private key.
LIFI_WALLET_ADDRESS=

# ── RPC endpoints (approve, deposit, allowance) ───────────────────────────────
# Required for on-chain calls. Add one entry per chain you use.
# The suffix must match the chain key shown by `lifi chains`.
# The chain ID (e.g. LIFI_RPC_8453 for Base) is always accepted as a fallback.
LIFI_RPC_BASE=https://mainnet.base.org
LIFI_RPC_OPT=https://mainnet.optimism.io
LIFI_RPC_ARBITRUM=https://arb1.arbitrum.io/rpc

# ── Optional ──────────────────────────────────────────────────────────────────
# LI.FI API key for higher rate limits. Public tier works without a key.
LIFI_API_KEY=

# Default chain when --chain is omitted.
LIFI_DEFAULT_FROM_CHAIN=base

# Default slippage in basis points (50 = 0.5%). Used when --slippage-bps is omitted.
LIFI_DEFAULT_SLIPPAGE_BPS=50
